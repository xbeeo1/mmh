<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_custom_footer_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.custom.footer</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='auto_printing']" position="before">
                <setting id="custom_footer" help="Add Custom Footer" >
                    <field name="pos_iface_custom_footer"/>
                    <div class="content-group mt16" invisible="not pos_iface_custom_footer">
                        <div>
                            <label string="Custom Footer" for="pos_custom_receipt_footer" class="col-lg-2 o_light_label"/>
                            <field name="pos_custom_receipt_footer" placeholder="Add Text"/>
                        </div>
                    </div>
                </setting>

            </xpath>

        </field>
    </record>

</odoo>