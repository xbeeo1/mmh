<?xml version="1.0"?>
<odoo>
        <record id="bulk_create_invoice_view_form" model="ir.ui.view">
            <field name="name">bulk.create.invoice.form</field>
            <field name="model">bulk.create.invoice</field>
            <field name="arch" type="xml">
                <form string="Bulk Create Invoice">
                <separator colspan="4"
                           string="Do you want to generate the bulk invoice(s)?"/>
                <newline/>
                <separator string="Create Bulk Invoice"
                           colspan="6"/>
                <footer>
                    <button name="bulk_create_invoice" string="Create"
                            type="object" class="oe_highlight"/>
                    or
                    <button special="cancel" string="Cancel"
                            class="oe_highlight"/>
                </footer>
            </form>
            </field>
        </record>

        <record id="bulk_create_invoice_action" model="ir.actions.act_window">
            <field name="name">Bulk Create Invoice</field>
            <field name="res_model">bulk.create.invoice</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="bulk_create_invoice_view_form"/>
            <field name="target">new</field>
            <field name="binding_model_id" ref="basic_hms.model_medical_lab"/>
        </record>
</odoo>
