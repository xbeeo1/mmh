<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_patient_village_tree" model="ir.ui.view">
            <field name="name">patient.village.tree</field>
            <field name="model">patient.village</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="description"/>
                </list>
            </field>
        </record>

        <!-- Form view -->
        <record id="view_patient_village_form" model="ir.ui.view">
            <field name="name">patient.village.form</field>
            <field name="model">patient.village</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>

                        <group>
                            <field name="name"/>
                            <field name="description"/>
                        </group>

                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_patient_village" model="ir.actions.act_window">
            <field name="name">Patient Village</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">patient.village</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create Your First Patient Village...!
                </p>
            </field>
        </record>

        <menuitem id="menu_patient_village"
                  name="Village"
                  parent="basic_hms.main_menu_configartion"
                  action="action_patient_village"
                  sequence="12"/>

    </data>
</odoo>
