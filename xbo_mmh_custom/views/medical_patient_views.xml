<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="basic_hms.report_print_patient_card" model="ir.actions.report">
        <field name="binding_model_id" eval="False"/>
        <field name="report_file"/>
        <field name="report_name"/>
        <field name="report_type">qweb-pdf</field>
    </record>

    <record id="medical_patients_tree_view_inherit" model="ir.ui.view">
        <field name="name">medical.patient.tree.inherit</field>
        <field name="model">medical.patient</field>
        <field name="inherit_id" ref="basic_hms.medical_patients_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='patient_id']" position="after">
                <field name="patient_mobile"/>
                <field name="patient_cnic"/>
            </xpath>

        </field>
    </record>

    <record id="medical_patients_form_view_inherit" model="ir.ui.view">
        <field name="name">medical.patient.form.inherit</field>
        <field name="model">medical.patient</field>
        <field name="inherit_id" ref="basic_hms.medical_patients_form_view"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet" position="inside">
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_prescriptions" type="object" class="oe_stat_button"
                            icon="fa-list">
                        <field name="prescription_count" widget="statinfo" string="Prescription"/>
                    </button>
                    <button name="action_view_invoices" type="object" class="oe_stat_button"
                            icon="fa-list">
                        <field name="invoice_count" widget="statinfo" string="Invoice"/>
                    </button>
                </div>
            </xpath>

            <xpath expr="//header" position="inside">
                <button name="action_view_create_prescription" type="object" string="Create Prescription" class="btn-primary" data-hotkey="q"/>
                <button name="action_create_invoice" invisible="invoice_count > 0" type="object" string="Create Invoice" class="btn-primary" data-hotkey="q"/>
            </xpath>

            <xpath expr="//button[@name='print_report']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="string">MR Number</attribute>
            </xpath>

            <xpath expr="//field[@name='name']" position="after">
                <field name="medical_patient_type_id"/>
                <field name="treatment_type_id"/>
            </xpath>

                <xpath expr="//label[@for='partner_address_id']" position="replace">
            </xpath>

            <xpath expr="//div[@class='o_address_format']" position="replace">
                <field name="street" placeholder="Street..." class="o_address_street" />
                <field name="street2" placeholder="Street 2..." class="o_address_street" />
                <field name="village_id" placeholder="Village" required="0"/>
                <field name="city" placeholder="City" class="o_address_city" />
                <field name="state_id" class="o_address_state" placeholder="State" options="{&quot;no_open&quot;: True}" />
                <field name="zip_code" placeholder="ZIP" class="o_address_zip"/>
                <field name="country_id" placeholder="Country" class="o_address_country"/>
            </xpath>

            <xpath expr="//field[@name='marital_status']" position="after">
                <field name="patient_mobile" required="0"/>
                <field name="patient_cnic"/>

            </xpath>

            <xpath expr="//field[@name='date_of_birth']" position="attributes">
                <attribute name="required">1</attribute>
            </xpath>
            <xpath expr="//field[@name='sex']" position="attributes">
                <attribute name="required">1</attribute>
            </xpath>

            <xpath expr="//field[@name='primary_care_physician_id']" position="after">
                <field name="department_id"/>
                <field name="treatment_fees"/>
            </xpath>

            <xpath expr="//field[@name='patient_id']" position="attributes">
                <attribute name="options">{'no_quick_create':True}</attribute>
            </xpath>

            <xpath expr="//field[@name='date_of_birth']" position="after">
                <field name="age" position="move"/>
                <field name="sex" position="move"/>
            </xpath>

        </field>
    </record>


    <record id="medical_patients_search_view" model="ir.ui.view">
        <field name="name">medical.patient.search.view</field>
        <field name="model">medical.patient</field>
        <field name="arch" type="xml">
            <search string="Search Patient">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="primary_care_physician_id"/>
                <field name="department_id"/>
                <field name="patient_mobile"/>
                <field name="patient_cnic"/>
                <field name="street"/>
                <field name="village_id"/>
                <field name="city"/>
                <separator/>
                <filter string="Patient" name="patient_id" domain="[('patient_id', '!=', False)]"/>
                <filter string="Mobile" name="patient_mobile" domain="[('patient_mobile', '!=', False)]"/>
                <filter string="Patient Type" name="medical_patient_type_id" domain="[('medical_patient_type_id', '!=', False)]"/>
                <group>
                    <filter string="Patient" name='patient_id' context="{'group_by':'patient_id'}"/>
                    <filter string="Patient Type" name='medical_patient_type_id' context="{'group_by':'medical_patient_type_id'}"/>
                    <filter string="Sex" name='sex' context="{'group_by':'sex'}"/>
                    <filter string="Primary Care Doctor" name='primary_care_physician_id' context="{'group_by':'primary_care_physician_id'}"/>
                    <filter string="Department" name='department_id' context="{'group_by':'department_id'}"/>
                    <filter string="Blood Type" name='blood_type' context="{'group_by':'blood_type'}"/>
                    <filter string="Village" name='village_id' context="{'group_by':'village_id'}"/>
                    <filter string="Address" name='street' context="{'group_by':'street'}"/>
                    <filter string="City" name='city' context="{'group_by':'city'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>