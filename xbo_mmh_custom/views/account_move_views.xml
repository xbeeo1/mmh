<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_invoice_tree_inherit" model="ir.ui.view" >
        <field name="name">account.move.tree.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="create_date" invisible="0" readonly="1"/>
                <field name="department_id" invisible="0"/>
                <field name="patient_type_id" invisible="0"/>
            </xpath>
        </field>
    </record>

    <record id="view_move_form_inherit" model="ir.ui.view" >
        <field name="name">account.move.form.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_vendor_bill_id']" position="after">
                <field name="partner_mobile" invisible="1"/>
                <field name="department_id" invisible="0" readonly="1"/>
                <field name="patient_type_id" invisible="0" readonly="1"/>
                <field name="doctor_id" invisible="0" readonly="1"/>
                <field name="outsourced_lab_request" invisible="0" readonly="1"/>
                 <field name="licence_status" readonly="1"/>
            </xpath>
            <xpath expr="//div[@name='journal_div']" position="after">
                <field name="employee_id" invisible="move_type != 'out_invoice'"/>
            </xpath>
        </field>
    </record>


    <record id="view_account_invoice_search_inherit" model="ir.ui.view">
        <field name="name">sdd.account.invoice.search</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ref']" position="after">
                <field name="department_id"/>
                <field name="patient_type_id"/>
                <field name="doctor_id"/>
                <field name="employee_id"/>
                <field name="partner_mobile" string="Mobile"/>
            </xpath>
            <xpath expr="//filter[@name='draft']" position="after">
                <filter name="department_id" string="Department" domain="[('department_id', '!=', False)]"/>
                <filter name="partner_mobile" string="Mobile" domain="[('partner_mobile', '!=', False)]"/>
                <filter name="patient_type_id" string="Patient Type" domain="[('patient_type_id', '!=', False)]"/>
                <filter name="doctor_id" string="Doctor" domain="[('doctor_id', '!=', False)]"/>
                <filter name="employee_id" string="Invoice Created By" domain="[('employee_id', '!=', False)]"/>
            </xpath>
            <xpath expr="//filter[@name='salesperson']" position="after">
                <filter string="Department" name="department_id" domain="[]" context="{'group_by': 'department_id'}"/>
                <filter string="Patient Type" name="patient_type_id" domain="[]" context="{'group_by': 'patient_type_id'}"/>
                <filter string="Doctor" name="doctor_id" domain="[]" context="{'group_by': 'doctor_id'}"/>
                <filter string="Invoice Created By" name="employee_id" domain="[]" context="{'group_by': 'employee_id'}"/>
                <filter string="Mobile" name="partner_mobile" domain="[]" context="{'group_by': 'partner_mobile'}"/>
            </xpath>
        </field>
    </record>



</odoo>
