<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_partner_lab_tree" model="ir.ui.view">
            <field name="name">partner.lab.tree</field>
            <field name="model">partner.lab</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                </list>
            </field>
        </record>

        <!-- Form view -->
        <record id="view_partner_lab_form" model="ir.ui.view">
            <field name="name">partner.lab.form</field>
            <field name="model">partner.lab</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                            </group>
                        </group>

                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_partner_lab" model="ir.actions.act_window">
            <field name="name">Partner Lab</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">partner.lab</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create Your First Patient type...!
                </p>
            </field>
        </record>

        <menuitem id="menu_partner_lab"
                  name="Partner Lab"
                  parent="basic_hms.main_menu_conf_laboratory"
                  action="action_partner_lab"
                  sequence="13"/>

    </data>
</odoo>
