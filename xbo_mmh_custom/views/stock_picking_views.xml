<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="emc_view_picking_form_inherit" model="ir.ui.view">
            <field name="name">stock.picking.form.inherit.emc</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='move_ids']//list//field[@name='product_id']" position="attributes">
                    <attribute name="options">{'no_quick_create': True, 'no_create_edit': True, 'no_open': True}</attribute>
                </xpath>


                <xpath expr="//field[@name='move_ids']/list//field[@name='product_uom_qty']" position="before">
                    <field name="batch_name" optional="show"/>
                    <field name="shelf_type" optional="show" column_invisible="True"/>
                    <field name="mrp_date" optional="show"/>
                    <field name="expiration_date" optional="show"/>
                    <field name="shelf_life" optional="show"/>
                </xpath>


            </field>
        </record>


    </data>
</odoo>
