<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_doctor_fees_rate_tree" model="ir.ui.view">
            <field name="name">doctor.fees.rate.tree</field>
            <field name="model">doctor.fees.rate</field>
            <field name="arch" type="xml">
                <list>
                    <field name="partner_id"/>
                    <field name="fee_rate"/>
                </list>
            </field>
        </record>

        <!-- Form view -->
        <record id="view_doctor_fees_rate_form" model="ir.ui.view">
            <field name="name">doctor.fees.rate.form</field>
            <field name="model">doctor.fees.rate</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>

                        <group>
                            <group>
                                <field name="partner_id"/>
                            </group>
                            <group>
                                <field name="fee_rate"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Doctor Fees History" name="fee_history">
                                <field name="doctor_fees_history_line" widget="section_and_note_one2many" readonly="1">
                                    <list string="Doctor Fees History" editable="bottom">
                                        <field name="partner_id"/>
                                        <field name="date"/>
                                        <field name="fee_rate"/>
                                    </list>
                                </field>
                            </page>

                        </notebook>

                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>


        <record id="view_doctor_fees_rate_search_view" model="ir.ui.view">
            <field name="name">doctor.fees.rate.search</field>
            <field name="model">doctor.fees.rate</field>
            <field name="arch" type="xml">
                <search string="Search Doctor">
                    <field name="partner_id"/>
                    <separator/>
                    <filter string="Doctor" name="partner_id" domain="[('partner_id', '!=', False)]"/>
                    <group>
                        <filter string="Doctor" name='partner_id' context="{'group_by':'partner_id'}"/>
                    </group>
                </search>
            </field>
        </record>


        <record id="action_doctor_fees_rate_view" model="ir.actions.act_window">
            <field name="name">Doctor Fees Rate</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">doctor.fees.rate</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create Your First Doctor Fess Rate...!
                </p>
            </field>
        </record>

        <menuitem id="menu_medical_doctor"
                  name="Doctor"
                  parent="basic_hms.main_menu_configartion"
                  sequence="7"/>

        <menuitem id="menu_doctor_fees_rate"
                  name="Doctor Fees Rate"
                  parent="xbo_mmh_custom.menu_medical_doctor"
                  action="action_doctor_fees_rate_view"
                  sequence="1"/>

    </data>
</odoo>
