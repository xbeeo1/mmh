<?xml version="1.0" encoding="utf-8"?>
<odoo>

     <record id="emc_view_production_lot_tree_inherit" model="ir.ui.view">
        <field name="name">stock.lot.tree.inherit.emc</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="string">Lots/Batch</attribute>
            </xpath>
            <xpath expr="//field[@name='create_date']" position="after">
                <field name="mrp_date"/>
                <field name="shelf_life"/>
                 <field name="sale_price"/>
            </xpath>
        </field>
    </record>

    <record id="stock.action_production_lot_form" model="ir.actions.act_window">
        <field name="name">Lots/Batch</field>
    </record>

    <record id="stock.menu_action_production_lot_form" model="ir.ui.menu">
        <field name="name">Lots/Batch</field>
    </record>

    <record id="emc_view_production_lot_form_inherit" model="ir.ui.view">
        <field name="name">stock.lot.form.inherit.emc</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="string">Lots/Batch</attribute>
            </xpath>
            <xpath expr="//group['1']" position="after">
                <group colspan="2">
                    <group>
                        <field name="mrp_date" readonly="1"/>
                        <field name="is_stock_move" invisible="1"/>
                        <field name="active" invisible="1"/>
                    </group>
                    <group>
                        <field name="shelf_life" readonly="1"/>
                        <field name="sale_price"/>
                    </group>
                </group>
                <group>
                    <field name="notification_date" invisible="0"/>
                </group>
            </xpath>
        </field>
    </record>


    <record id="emc_search_product_lot_filter_inherit" model="ir.ui.view">
        <field name="name">stock.lot.search.inherit.emc</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.search_product_lot_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="shelf_life"/>
                <field name="mrp_date"/>
            </xpath>

            <xpath expr="//filter[@name='at_customer']" position="after">
                <filter string="Shelf Life" name="shelf_life" domain="[('shelf_life', '!=', False)]"/>
                <filter string="Mrp Date" name="mrp_date" domain="[('mrp_date', '!=', False)]"/>
                <filter string="Archived" name="active" domain="[('active', '!=', True)]"/>
                <filter string="Un Archived" name="active" domain="[('active', '!=', False)]"/>
            </xpath>
            <xpath expr="//group/filter[@name='group_by_product']" position="after">
                <filter name="shelf_life" string="Shelf Life" domain="[]" context="{'group_by' : 'shelf_life'}"/>
                <filter name="mrp_date" string="Mrp Date" domain="[]" context="{'group_by' : 'mrp_date'}"/>
            </xpath>

        </field>
    </record>


</odoo>
