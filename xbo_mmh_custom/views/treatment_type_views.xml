<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_treatment_type_tree" model="ir.ui.view">
            <field name="name">treatment.type.tree</field>
            <field name="model">treatment.type</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="description"/>
                </list>
            </field>
        </record>

        <!-- Form view -->
        <record id="view_treatment_type_form" model="ir.ui.view">
            <field name="name">treatment.type.form</field>
            <field name="model">treatment.type</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>

                        <group>
                            <field name="name"/>
                            <field name="description"/>
                        </group>

                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_treatment_type" model="ir.actions.act_window">
            <field name="name">Treatment Type</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">treatment.type</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create Your First Treatment Type...!
                </p>
            </field>
        </record>

        <menuitem id="menu_treatment_type"
                  name="Treatment Types"
                  parent="basic_hms.main_menu_configartion"
                  action="action_treatment_type"
                  sequence="13"/>

    </data>
</odoo>
