<odoo>
    <record id="view_report_signatory_list" model="ir.ui.view">
        <field name="name">report.signatory.list</field>
        <field name="model">report.signatory</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence"/>
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_report_signatory_form" model="ir.ui.view">
        <field name="name">report.signatory.form</field>
        <field name="model">report.signatory</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="sequence" readonly="1"/>
                        <field name="name"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_report_signatory" model="ir.actions.act_window">
        <field name="name">Report Signatories</field>
        <field name="res_model">report.signatory</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem name="Report Signatories"
              id="menu_report_signatory"
              parent="basic_hms.main_menu_conf_laboratory"
              action="action_report_signatory" sequence='25'/>

</odoo>