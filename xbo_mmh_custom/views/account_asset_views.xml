<odoo>

    <record id="view_account_asset_form_inherit" model="ir.ui.view">
        <field name="name">account.asset.form.inherit</field>
        <field name="model">account.asset.asset</field>
        <field name="inherit_id" ref="om_account_asset.view_account_asset_asset_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[2]" position="after">
                <group>
                    <group>
                        <field name="medical_room_id"/>
                        <field name="department_id"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

</odoo>

