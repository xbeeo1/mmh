<?xml version="1.0" encoding="utf-8"?>
<odoo>



    <record id="pos_view_production_lot_form_inherit" model="ir.ui.view">
        <field name="name">stock.lot.form.inherit.pos</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group['1']" position="after">
                <group colspan="2">
                    <group>
                        <field name="sale_price" string="Pos Sale Price"/>
                    </group>
                </group>

            </xpath>
        </field>
    </record>





</odoo>
