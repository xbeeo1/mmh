<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="paperformat_multidays_profit_loss" model="report.paperformat">
            <field name="name">Multi-days profit Loss</field>
            <field name="default" eval="True" />
            <field name="format">custom</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">52</field>
            <field name="margin_bottom">32</field>
            <field name="margin_left">0</field>
            <field name="margin_right">0</field>
            <field name="header_line" eval="False" />
            <field name="header_spacing">52</field>
            <field name="dpi">90</field>
            <field name="css_margins" eval="True" />
        </record>




        <record id="action_multidays_profit_loss_report" model="ir.actions.report">
            <field name="name">Multi-Days Profit/Loss Report</field>
            <field name="model">pos.order</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">xbo_mmh_report.multidays_profit_loss_report_template</field>
            <field name="report_file">xbo_mmh_report.multidays_profit_loss_report_template</field>
            <field name="paperformat_id" ref="paperformat_multidays_profit_loss"/>
            <field name="binding_type">report</field>
            <field name="print_report_name">'Multi-Days Profit/Loss Report'</field>
        </record>


        <record id="action_pos_profit_loss_report" model="ir.actions.report">
            <field name="name">POS Profit &amp; Loss</field>
            <field name="model">pos.order</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">xbo_mmh_report.report_pos_profit_loss</field>
            <field name="report_file">xbo_mmh_report.report_pos_profit_loss</field>
            <field name="binding_model_id" ref="point_of_sale.model_pos_order"/>
            <field name="binding_type">report</field>
            <field name="print_report_name">'POS Profit &amp; Loss'</field>
        </record>


    </data>
</odoo>